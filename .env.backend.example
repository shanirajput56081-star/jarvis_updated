# ============================================================
# BACKEND env vars — set these in Railway / Render dashboard
# (Settings -> Variables / Environment). Do NOT commit real values.
# ============================================================

# Your Gemini API key (required)
GEMINI_API_KEY="your_actual_gemini_api_key_here"

# Tells server.ts to run in production mode (skips Vite dev middleware)
NODE_ENV="production"

# Your cPanel frontend URL — restricts CORS to only your domain.
# Example: https://yourdomain.com  (no trailing slash)
FRONTEND_URL="https://yourdomain.com"

# PORT is usually auto-injected by Railway/Render — you normally
# don't need to set this yourself.
