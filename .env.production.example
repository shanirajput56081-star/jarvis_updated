# ============================================================
# FRONTEND production env (used only at BUILD TIME by Vite)
# ============================================================
# Copy this file to ".env.production" before running `npm run build`.
# This value gets baked into the built JS files, so the frontend
# (hosted on your cPanel) knows where to reach the WebSocket backend
# (hosted on Railway/Render/etc).
#
# Replace with YOUR actual backend URL once deployed.
# Must start with wss:// (secure) since your cPanel site will be https.
VITE_BACKEND_WS_URL="wss://your-backend-app.up.railway.app/live"
